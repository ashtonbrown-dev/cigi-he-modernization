/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",                ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "Save &As...",                 ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "Load &Configuration...",      ID_FILE_LOAD_CONFIG
        MENUITEM SEPARATOR
        MENUITEM "S&etup...",                   ID_FILE_SETUP
        MENUITEM SEPARATOR
        MENUITEM "Recent File",                 ID_FILE_MRU_FILE1
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
    END
    POPUP "&Actions"
    BEGIN
        POPUP "&Send Packet"
        BEGIN
            MENUITEM "Acceleration Control...",     ID_PACKET_ACCELERATION
            MENUITEM "Animation Control...",        ID_PACKET_ANIMATIONCONTROL
            MENUITEM "Articulated Part Control...", ID_PACKET_ARTPART
            MENUITEM "Atmosphere Control...",       ID_PACKET_ATMOSPHERE
            MENUITEM "Celestial Sphere Control...", ID_PACKET_CELSPHERE
            MENUITEM "Collision Detection Segment Definition...", ID_PACKET_CD_SEGMENT
            MENUITEM "Collision Detection Volume Definition...", ID_PACKET_CD_VOLUME
            MENUITEM "Component Control...",        ID_PACKET_COMPONENT
            MENUITEM "Conformal Clamped Entity Position...", ID_PACKET_CLAMPED_ENTITY_POSITION
            MENUITEM "Earth Reference Model Definition...", ID_PACKET_ERM
            MENUITEM "Entity Control...",           ID_PACKET_ENTITY
            MENUITEM "Entity Position...",          ID_PACKET_ENTITY_POSITION
            MENUITEM "Environmental Conditions Request...", ID_PACKET_ENV_COND
            MENUITEM "Environmental Region Control...", ID_PACKET_ENV_REGION
            MENUITEM "HAT/HOT Request...",          ID_PACKET_HAT
            MENUITEM "IG Control...",               ID_PACKET_IG_CONTROL
            MENUITEM "Line of Sight Segment Request...", ID_PACKET_LOS_SEGMENT
            MENUITEM "Line of Sight Vector Request...", ID_PACKET_LOS_VECTOR
            MENUITEM "Maritime Surface Conditions Control...", ID_PACKET_MARITIME
            MENUITEM "Motion Tracker Control...",   ID_PACKET_MOTION_TRACKER
            MENUITEM "Position Request...",         ID_PACKET_POSITION
            MENUITEM "Sensor Control...",           ID_PACKET_SENSOR
            MENUITEM "Short Articulated Part Control...", ID_PACKET_SHORT_ARTPART
            MENUITEM "Short Component Control...",  ID_PACKET_SHORT_COMPONENT
            MENUITEM "Short Symbol Control...",     ID_PACKET_SHORTSYMBOLCONTROL
            MENUITEM "Symbol Circle Definition...", ID_PACKET_SYMBOLCIRCLEDEFINITION
            MENUITEM "Symbol Clone...",             ID_PACKET_SYMBOLCLONE
            MENUITEM "Symbol Control...",           ID_PACKET_SYMBOLCONTROL
            MENUITEM "Symbol Polygon Definition...", ID_PACKET_SYMBOLPOLYGONDEFINITION
            MENUITEM "Symbol Surface Definition...", ID_PACKET_SYMBOLSURFACEDEFINITION
            MENUITEM "Symbol Textured Circle Definition...", ID_PACKET_SYMBOLTEXTUREDCIRCLEDEFINITION
            MENUITEM "Symbol Textured Polygon Definition", ID_PACKET_SYMBOLTEXTUREDPOLYGONDEFINITION
            MENUITEM "Symbol Text Definition...",   ID_PACKET_SYMBOLTEXTDEFINITION
            MENUITEM "Terrestrial Surface Conditions Control...", ID_PACKET_TERRESTRIAL
            MENUITEM "Velocity Control...",         ID_PACKET_VELOCITY
            MENUITEM "View Control...",             ID_PACKET_VIEW_CONTROL
            MENUITEM "View Definition...",          ID_PACKET_VIEW_DEF
            MENUITEM "Wave Control...",             ID_PACKET_WAVE
            MENUITEM "Weather Control...",          ID_PACKET_WEATHER
        END
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Toolbar",                    ID_VIEW_TOOLBAR
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM "S&plit",                      ID_WINDOW_SPLIT
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Contents...",                ID_HELP_CONTENTS
        MENUITEM "&Index...",                   ID_HELP_INDEX
        MENUITEM SEPARATOR
        MENUITEM "&About CIGI Host Emulator 4...", ID_APP_ABOUT
    END
END

IDR_CONFIGURATION MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Load Template...\tCtrl+L",   ID_FILE_LOAD_TEMPLATE
        MENUITEM "&Save Template...\tCtrl+S",   ID_FILE_SAVE_TEMPLATE
        MENUITEM "Save as Default",             ID_FILE_SAVE_AS_DEFAULT
        MENUITEM SEPARATOR
        MENUITEM "Recent File",                 ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "&Close",                      ID_CONFIG_CLOSE
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Toolbar",                    ID_VIEW_TOOLBAR
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM SEPARATOR
        MENUITEM "&Configuration...",           ID_VIEW_CONFIGURATION
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Help Topics",                ID_HELP_FINDER
        MENUITEM SEPARATOR
    END
END



IDD_PACKET_ANIMATION_CONTROL DIALOGEX 0, 0, 238, 147
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Send Animation Control Packet"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    CONTROL         "",IDC_COMBOBOXEX_ENTITY_ID,"ComboBoxEx32",CBS_DROPDOWN | CBS_SORT | WS_VSCROLL | WS_TABSTOP,57,8,116,80
    EDITTEXT        IDC_EDIT_ALPHA,181,54,40,14,ES_AUTOHSCROLL
    CONTROL         "Inherit Alpha from Parent",IDC_CHECK_INHERIT_ALPHA,
                    "Button",BS_AUTOCHECKBOX | WS_TABSTOP,20,60,93,10
    CONTROL         "Stop",IDC_RADIO_ANIM_STATE_STOP,"Button",BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,37,106,31,10
    CONTROL         "Play",IDC_RADIO_ANIM_STATE_PLAY,"Button",BS_AUTORADIOBUTTON | WS_TABSTOP,37,121,29,10
    CONTROL         "Continue",IDC_RADIO_ANIM_STATE_CONTINUE,"Button",BS_AUTORADIOBUTTON | WS_GROUP | WS_TABSTOP,114,106,44,10
    CONTROL         "Reset",IDC_RADIO_ANIM_STATE_PAUSE,"Button",BS_AUTORADIOBUTTON | WS_TABSTOP,114,121,35,10
    CONTROL         "Loop Animation Sequence",IDC_CHECK_ANIM_LOOP,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,19,77,99,10
    DEFPUSHBUTTON   "Send",IDOK,178,7,50,14
    PUSHBUTTON      "Close",IDCANCEL,178,24,50,14
    LTEXT           "Entity ID:",IDC_STATIC,23,10,30,8
    LTEXT           "Alpha:",IDC_STATIC,158,60,21,8
    LTEXT           "Animation State:",IDC_STATIC,30,96,52,8
    GROUPBOX        "Properties",IDC_STATIC,7,46,221,93
    LTEXT           "Animation Frame Position Reset",IDC_STATIC,108,96,108,8
    CONTROL         "",IDC_COMBOBOXEX_ANIMATION_ID,"ComboBoxEx32",CBS_DROPDOWN | CBS_SORT | WS_VSCROLL | WS_TABSTOP,57,26,116,80
    LTEXT           "Animation ID:",IDC_STATIC,10,27,43,8
    EDITTEXT        IDC_EDIT_SPEED,181,73,40,14,ES_AUTOHSCROLL
    LTEXT           "Animation Speed:",IDC_STATIC,124,77,58,8
END



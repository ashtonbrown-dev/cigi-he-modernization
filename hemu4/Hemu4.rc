    LTEXT           "degrees",IDC_LABEL_UNITS_Y,93,80,26,8
    LTEXT           "meters",IDC_LABEL_UNITS_Z,93,98,22,8
    LTEXT           "degrees",IDC_LABEL_YAW_UNITS,205,62,26,8
    LTEXT           "degrees",IDC_LABEL_PITCH_UNITS,205,80,26,8
    LTEXT           "degrees",IDC_LABEL_ROLL_UNITS,205,98,26,8
    RTEXT           "Yaw:",IDC_LABEL_YAW,125,62,32,8
    RTEXT           "Pitch:",IDC_LABEL_PITCH,125,80,32,8
    RTEXT           "Roll:",IDC_LABEL_ROLL,125,98,32,8
